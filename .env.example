# Required Splunk Observability Cloud settings.
# Copy this file to .env, replace both values, and never commit .env.
SPLUNK_ACCESS_TOKEN=replace-with-an-observability-ingest-access-token
SPLUNK_REALM=us0

# Optional endpoint overrides. Leave commented to derive current Splunk endpoints
# from SPLUNK_REALM. Set these when using a proxy or legacy signalfx.com domains.
# SPLUNK_API_URL=https://api.us0.observability.splunkcloud.com
# SPLUNK_INGEST_URL=https://ingest.us0.observability.splunkcloud.com
# SPLUNK_TRACE_URL=https://ingest.us0.observability.splunkcloud.com/v2/trace
# SPLUNK_HEC_URL=https://ingest.us0.observability.splunkcloud.com/v1/log
# SPLUNK_HEC_TOKEN=replace-only-if-different-from-SPLUNK_ACCESS_TOKEN

# Pinned instrumentation component versions.
SPLUNK_OTEL_JAVA_AGENT_VERSION=2.29.0
SPLUNK_OTEL_COLLECTOR_VERSION=0.156.0

# OpenTelemetry resource identity.
OTEL_SERVICE_NAME=profiling-demo
OTEL_SERVICE_VERSION=1.0.0
OTEL_DEPLOYMENT_ENVIRONMENT=demo

# AlwaysOn Profiling.
SPLUNK_PROFILER_ENABLED=true
SPLUNK_PROFILER_MEMORY_ENABLED=true
SPLUNK_PROFILER_CALL_STACK_INTERVAL=10000ms
SPLUNK_PROFILER_MEMORY_EVENT_RATE=150/s

# Telemetry and diagnostics.
SPLUNK_METRICS_ENABLED=true
OTEL_METRICS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_TIMEOUT=10000
OTEL_JAVAAGENT_DEBUG=false
SPLUNK_MEMORY_LIMIT_MIB=512
SPLUNK_COLLECTOR_LOG_LEVEL=info

# Application workload settings.
DEMO_PORT=8080
DEMO_BLOCKING_WORKER_COUNT=8
DEMO_BLOCKING_LOCK_HOLD_MILLIS=900
DEMO_BLOCKING_GAP_MILLIS=50
DEMO_MEMORY_ALLOCATION_MEGABYTES=1
DEMO_MEMORY_ALLOCATION_INTERVAL_MILLIS=250
DEMO_MEMORY_MAX_RETAINED_MEGABYTES=128
JAVA_TOOL_OPTIONS=-Xms256m -Xmx384m
